# ============================================================================
# Environment Configuration - Maritime Zero Trust Architecture
# IMPORTANT: Copy this file to .env and update with real values
# NEVER commit .env to version control
# ============================================================================

# ====================
# PROJECT METADATA
# ====================
PROJECT_NAME=maritime-zta
ENVIRONMENT=development
TZ=UTC

# ====================
# MONGODB CONFIGURATION
# ====================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
MONGO_DATABASE=maritime_zta
MONGO_HOST=db_primary
MONGO_PORT=27017

# ====================
# SPLUNK SIEM
# ====================
SPLUNK_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
SPLUNK_HEC_TOKEN=CHANGE_ME_RANDOM_UUID_HERE
# Generate with: python -c "import uuid; print(uuid.uuid4())"

# ====================
# OPA POLICY ENGINE
# ====================
OPA_LOG_LEVEL=info
OPA_LOG_FORMAT=json

# ====================
# ENVOY PROXY
# ====================
ENVOY_LOG_LEVEL=info
ENVOY_ADMIN_PORT=9901
ENVOY_LISTENER_PORT=8443

# ====================
# PKI/CERTIFICATES
# ====================
CA_COUNTRY=US
CA_STATE=California
CA_CITY=San Francisco
CA_ORG=Maritime Operations
CA_OU=Security Team
CA_COMMON_NAME=Maritime Root CA
CA_VALIDITY_DAYS=3650
CERT_VALIDITY_DAYS=365

# ====================
# SECURITY SETTINGS
# ====================
# Risk score threshold (0-100)
RISK_SCORE_THRESHOLD=80

# Session timeout (seconds)
SESSION_TIMEOUT=3600

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=100

# ====================
# LOGGING & MONITORING
# ====================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_RETENTION_DAYS=90

# ====================
# NETWORK CONFIGURATION
# ====================
# Docker network subnets
NETWORK_PERIMETER_SUBNET=172.20.1.0/24
NETWORK_ZTA_SUBNET=172.20.2.0/24
NETWORK_BACKEND_SUBNET=172.20.3.0/24
NETWORK_MONITORING_SUBNET=172.20.4.0/24
NETWORK_CLIENTS_SUBNET=172.20.5.0/24

# ====================
# DOCKER CONFIGURATION
# ====================
COMPOSE_PROJECT_NAME=maritime-zta
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROFILES=

# ====================
# DEVELOPMENT SETTINGS
# ====================
# Set to 'true' for development, 'false' for production
DEBUG=false
ENABLE_PROFILING=false

# ====================
# BACKUP & RECOVERY
# ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ====================
# COMPLIANCE
# ====================
# Audit log retention (days)
AUDIT_RETENTION_DAYS=365

# Enable detailed audit logging
AUDIT_DETAILED=true

# ====================
# FEATURE FLAGS
# ====================
FEATURE_RATE_LIMITING=true
FEATURE_GEO_BLOCKING=false
FEATURE_BEHAVIORAL_ANALYSIS=true

# ====================
# EXTERNAL INTEGRATIONS (Optional)
# ====================
# SIEM_EXTERNAL_URL=
# SIEM_EXTERNAL_TOKEN=

# THREAT_INTEL_API_KEY=
# THREAT_INTEL_ENDPOINT=

# ====================
# PRODUCTION OVERRIDES
# ====================
# Uncomment and set for production
# MONGO_REPLICA_SET=rs0
# ENABLE_TLS_EVERYWHERE=true
# ENFORCE_STRONG_AUTH=true
